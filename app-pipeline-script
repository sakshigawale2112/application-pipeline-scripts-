pipeline {
    agent any

    parameters {
        choice(name: 'ENV', choices: ['dev', 'stage', 'prod'], description: 'Select Environment')
    }

    environment {
        BACKEND_IMAGE = "sakshigawale2112/easy-deploy-backend:${params.ENV}"
        FRONTEND_IMAGE = "sakshigawale2112/easy-deploy-frontend:${params.ENV}"
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: 'main',
                url: 'https://github.com/jambhulkarcloudblitz-alt/CDEC-studentapp.git'
            }
        }

        stage('Build Backend') {
            steps {
                sh '''
                    cd backend
                    mvn clean package -DskipTests
                '''
            }
        }

        stage('Build Frontend') {
            steps {
                sh '''
                    cd frontend
                    npm install
                    npm run build
                '''
            }
        }

        stage('Docker Build & Push') {
            steps {
                withCredentials([
                    string(credentialsId: 'docker-username', variable: 'DOCKER_USERNAME'),
                    string(credentialsId: 'docker-cred', variable: 'DOCKER_PASSWORD')
                ]) {
                    sh '''
                        echo "$DOCKER_PASSWORD" | docker login -u "$DOCKER_USERNAME" --password-stdin

                        # Backend
                        cd backend
                        docker build -t $BACKEND_IMAGE .
                        docker push $BACKEND_IMAGE

                        # Frontend
                        cd ../frontend
                        docker build -t $FRONTEND_IMAGE .
                        docker push $FRONTEND_IMAGE
                    '''
                }
            }
        }

        stage('Deploy to K8s') {
            steps {
                sh '''
                    kubectl apply -f k8s/${ENV}/
                '''
            }
        }
    }
}
